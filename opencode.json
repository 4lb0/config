{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "cp *": "ask",
      "mv *": "ask",
      "dd *": "ask",
      "sudo *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "npm install *": "ask",
      "pip install *": "ask",
      "git reset --hard *": "ask",
      "git clean *": "ask",
      "reboot": "ask",
      "shutdown": "ask",
      "kill *": "ask",
      "killall *": "ask",
      "docker *": "ask",
      "mkfs *": "ask",
      "fdisk *": "ask",
      "parted *": "ask",
      "format *": "ask",
      "npm run publish": "ask",
      "brew install *": "ask",
      "ssh *": "ask",
      "scp *": "ask",
      "rsync *": "ask"
    },
    "doom_loop": "ask",
    "external_directory": {
      "*": "ask",
      "/tmp": "allow",
      "/tmp/*": "allow"
    }
  }
}
